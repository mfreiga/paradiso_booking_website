# Copy this file to `.env` and fill in the values. (`.env` is gitignored.)

# Postgres connection string (matches docker-compose.yml for local dev)
DATABASE_URL="postgresql://paradiso:paradiso@localhost:5432/paradiso?schema=public"

# Shop timezone (IANA name)
SHOP_TIMEZONE="Europe/Berlin"

# ── Auth & email (used from M2 onward) ──
# Generate with:  npx auth secret   (or:  openssl rand -base64 33)
AUTH_SECRET=""
# Resend API key — transactional emails (booking confirmations). Empty = console log in dev.
RESEND_API_KEY=""
EMAIL_FROM="Paradiso <onboarding@resend.dev>"
# Comma-separated list of emails allowed to access /admin
ADMIN_EMAILS=""
# Admin login password (dev placeholder)
ADMIN_PASSWORD=""
