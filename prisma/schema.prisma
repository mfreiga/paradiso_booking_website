// Paradiso booking — data model. See SPEC.md §6.
// Prisma 7: new `prisma-client` generator → outputs to src/generated/prisma.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ─────────────────────────────────────────────────────

enum Gender {
  MEN
  WOMEN
  UNISEX
}

enum StaffGender {
  MALE
  FEMALE
}

enum PriceType {
  FIXED
  FROM
  ON_REQUEST
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentSource {
  CUSTOMER
  ADMIN
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
}

// ── Catalog ───────────────────────────────────────────────────

model Category {
  id           String    @id @default(cuid())
  name         String
  gender       Gender
  displayOrder Int       @default(0)
  isActive     Boolean   @default(true)
  services     Service[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([gender, displayOrder])
}

model Service {
  id               String            @id @default(cuid())
  name             String
  description      String?
  gender           Gender
  categoryId       String
  category         Category          @relation(fields: [categoryId], references: [id])
  isAddOn          Boolean           @default(false)
  isPopular        Boolean           @default(false)
  isActive         Boolean           @default(true)
  displayOrder     Int               @default(0)
  variants         ServiceVariant[]
  stylists         StylistService[]
  appointmentItems AppointmentItem[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([gender, categoryId, displayOrder])
}

// Price + duration for a service. One row ("Standard") for flat-priced
// services; three rows (Kurz/Mittel/Lang) for length-tiered ones.
model ServiceVariant {
  id               String            @id @default(cuid())
  serviceId        String
  service          Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  label            String
  priceCents       Int
  priceType        PriceType         @default(FIXED)
  durationMinutes  Int
  displayOrder     Int               @default(0)
  appointmentItems AppointmentItem[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([serviceId, displayOrder])
}

// ── Staff & availability ──────────────────────────────────────

model Stylist {
  id           String           @id @default(cuid())
  name         String
  gender       StaffGender
  bio          String?
  photoUrl     String?
  isActive     Boolean          @default(true)
  displayOrder Int              @default(0)
  services     StylistService[]
  workingHours WorkingHours[]
  timeOff      TimeOff[]
  appointments Appointment[]
  reviews      Review[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([isActive, displayOrder])
}

// Which stylist can perform which service (M:N).
model StylistService {
  stylistId String
  serviceId String
  stylist   Stylist @relation(fields: [stylistId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([stylistId, serviceId])
  @@index([serviceId])
}

// Recurring weekly availability. weekday: 1=Mon … 7=Sun (Luxon convention).
// startMinutes/endMinutes: minutes from midnight, shop-local time.
model WorkingHours {
  id           String   @id @default(cuid())
  stylistId    String
  stylist      Stylist  @relation(fields: [stylistId], references: [id], onDelete: Cascade)
  weekday      Int
  startMinutes Int
  endMinutes   Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([stylistId, weekday])
}

// One-off unavailability (vacation, break, sick, manual block).
model TimeOff {
  id        String   @id @default(cuid())
  stylistId String
  stylist   Stylist  @relation(fields: [stylistId], references: [id], onDelete: Cascade)
  startAt   DateTime @db.Timestamptz(3)
  endAt     DateTime @db.Timestamptz(3)
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stylistId, startAt])
}

// ── Customers & bookings ──────────────────────────────────────

// Lightweight, no-password. Auto looked-up/created by email at booking
// so admin can see a customer's history.
model Customer {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  phone        String?
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Appointment {
  id                   String            @id @default(cuid())
  stylistId            String
  stylist              Stylist           @relation(fields: [stylistId], references: [id])
  customerId           String?
  customer             Customer?         @relation(fields: [customerId], references: [id])
  customerName         String
  customerEmail        String
  customerPhone        String
  startAt              DateTime          @db.Timestamptz(3)
  endAt                DateTime          @db.Timestamptz(3)
  status               AppointmentStatus @default(CONFIRMED)
  totalPriceCents      Int
  totalDurationMinutes Int
  priceIsFrom          Boolean           @default(false)
  customerNote         String?
  adminNote            String?
  manageToken          String            @unique
  reviewToken          String            @unique
  source               AppointmentSource @default(CUSTOMER)
  items                AppointmentItem[]
  review               Review?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([stylistId, startAt])
  @@index([startAt])
  @@index([status])
}

// Services in a booking — snapshotted so history stays correct if the
// menu later changes.
model AppointmentItem {
  id                      String          @id @default(cuid())
  appointmentId           String
  appointment             Appointment     @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceId               String?
  service                 Service?        @relation(fields: [serviceId], references: [id])
  serviceVariantId        String?
  serviceVariant          ServiceVariant? @relation(fields: [serviceVariantId], references: [id])
  nameSnapshot            String
  variantLabelSnapshot    String
  priceCentsSnapshot      Int
  durationMinutesSnapshot Int

  @@index([appointmentId])
}

model Review {
  id            String       @id @default(cuid())
  stylistId     String
  stylist       Stylist      @relation(fields: [stylistId], references: [id], onDelete: Cascade)
  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  displayName   String
  rating        Int
  comment       String?
  status        ReviewStatus @default(PENDING)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([stylistId, status])
}

// Singleton config row (id = 1). See SPEC §15.
model Setting {
  id                    Int      @id @default(1)
  timezone              String   @default("Europe/Berlin")
  slotGranularityMin    Int      @default(15)
  defaultBufferMin      Int      @default(0)
  bookingWindowDays     Int      @default(60)
  minLeadTimeMin        Int      @default(120)
  cancellationCutoffMin Int      @default(120)
  shopName              String   @default("Hairstyling Paradiso")
  shopPhone             String   @default("089 - 32 66 81 82")
  shopAddress           String?
  updatedAt             DateTime @updatedAt
}

// ── Auth.js (admin login only) — see SPEC §3 ──────────────────
// Sign-in is restricted to emails in ADMIN_EMAILS (enforced in src/auth.ts).
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("ADMIN")
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}
